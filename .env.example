# App mode
ENV=dev
LOG_LEVEL=INFO

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///artifacts/hkjc_football.db

# Data source tag used in reporting (HKJC or NON_HKJC)
DATA_SOURCE_TAG=NON_HKJC

# Feature CSV defaults by phase
PHASE2_FEATURE_CSV_PATH=data/processed/features_mvp.csv
PHASE3_FEATURE_CSV_PATH=data/processed/features_phase3.csv
PHASE3_FULL_RAW_CSV_PATH=data/raw/real/historical_matches_real_non_hkjc.csv
PHASE3_FULL_FEATURE_CSV_PATH=data/processed/features_phase3_full.csv
PHASE3_HKJC_FEATURE_CSV_PATH=data/processed/features_phase3_hkjc.csv
# Dataset scope for backtest loader: AUTO | NON_HKJC | HKJC | MIXED
BACKTEST_DATASET_SCOPE=AUTO
FOOTBALL_DATA_SOURCE_URLS=https://www.football-data.co.uk/mmz4281/2324/E0.csv

# Strategy defaults (Phase 6 recommended baseline from optimizer best params)
MIN_EDGE_THRESHOLD=0.02
MIN_CONFIDENCE_THRESHOLD=0.56
MAX_CONCURRENT_BETS=5
MAX_DAILY_EXPOSURE=0.05
SKIP_MISSING_DATA=true
FLAT_STAKE=100

# Phase 3 model and backtest defaults
MODEL_NAME=logistic_regression
MODEL_APPROACH=direct_cover
INCLUDE_MARKET_FEATURES=true
MIN_TRAIN_MATCHES=12
WALKFORWARD_TEST_WINDOW=4
RETRAIN_EVERY_MATCHES=4
PURGE_GAP_MATCHES=0
ODDS_SOURCE=closing

# Bankroll defaults (Phase 6 recommended baseline)
BANKROLL_MODE=fractional_kelly
BANKROLL_INITIAL=10000
BANKROLL_FIXED_FRACTION_PCT=0.01
FRACTIONAL_KELLY_FACTOR=0.15
VOL_TARGET_ROLLING_WINDOW_BETS=20
VOL_TARGET_TARGET_PER_BET_VOL=0.03
KELLY_CAP=0.02
BANKROLL_MAX_STAKE_PCT=0.01
BANKROLL_MIN_STAKE=10
BANKROLL_DAILY_MAX_EXPOSURE_PCT=0.03
BANKROLL_MAX_DRAWDOWN_PCT=0.25
# Leave empty to disable daily stop loss
BANKROLL_DAILY_STOP_LOSS_PCT=

# Optimizer objective weights (Phase 4)
OPTIMIZER_LAMBDA_DRAWDOWN=0.5
OPTIMIZER_LAMBDA_LOW_BETS=0.1
OPTIMIZER_MIN_BETS_TARGET=10

# Telegram (Phase 4)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Safe initial cloud/live default: keep dry-run enabled first deployment.
TELEGRAM_DRY_RUN=true
