{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.envFile": "${workspaceFolder}/.env",
  "python.analysis.typeCheckingMode": "basic",
  "files.exclude": {
    "**/__pycache__": true
  },
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "chat.tools.terminal.autoApprove": {
    "/^py -3\\.11 --version$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "c:/Users/lccqs/Football-predictor/.venv/Scripts/python.exe": true,
    "git rev-parse": true,
    "/^git rm -r --cached --quiet artifacts$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^git add artifacts/\\.gitkeep$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^git diff -- \\.gitignore$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^git add \\.gitignore config/data_retention_policy\\.yml$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^python \\.github/scripts/send_telegram_report\\.py --help$/": {
      "approve": true,
      "matchCommandLine": true
    },
    ".github/workflows/scheduled-backtest.yml": true,
    ".github/scripts/send_telegram_report.py": true
  },
  "python.analysis.autoImportCompletions": true
}
